{
  "name": "ppos-build-orchestrator",
  "private": true,
  "version": "0.1.0",
  "description": "Industrial Build Orchestrator for PrintPrice OS",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm test",
    "test:v33": "node tests/v33-master-test.js",
    "bootstrap:foundation": "node scripts/bootstrap/run-foundation-bootstrap.mjs",
    "verify:scaffold": "node scripts/verify/verify-scaffold.mjs",
    "verify:contracts": "node scripts/verify/verify-runtime-contracts.mjs",
    "verify:dashboards": "node scripts/verify/verify-dashboard-artifacts.mjs",
    "dev:dashboard": "node scripts/dev/run-local-dashboard.mjs",
    "dev:cli": "node scripts/dev/run-local-cli.mjs"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.21.5"
    }
  }
}