{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "FEP Governance Assertion",
    "type": "object",
    "required": [
        "assertionId",
        "policyProfile",
        "status"
    ],
    "properties": {
        "assertionId": {
            "type": "string"
        },
        "policyProfile": {
            "type": "string"
        },
        "status": {
            "enum": [
                "approved",
                "denied",
                "pending_review"
            ]
        },
        "violations": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "metadata": {
            "type": "object"
        }
    }
}