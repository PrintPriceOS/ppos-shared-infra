{
    "slug": "DIGITAL_POD",
    "name": "Digital Print-on-Demand",
    "description": "Print-on-demand for books and short runs. Accepts RGB and CMYK. Bleed optional but recommended. Ideal for single-copy and short-run digital presses.",
    "category": "digital",
    "tier": "standard",
    "color": {
        "mode": "any",
        "icc_profile": "PSO_Coated_v3.icc",
        "convert_rgb": false,
        "tac_limit": 280,
        "allow_spot_colors": false,
        "spot_color_whitelist": [],
        "require_output_intent": false,
        "flatten_transparency": false,
        "render_intent": 1
    },
    "document": {
        "bleed_mm_required": 0,
        "min_resolution_dpi": 150,
        "max_pages": 800,
        "max_file_mb": 300,
        "max_spot_colors": 0,
        "allowed_pdf_versions": [
            "1.3",
            "1.4",
            "1.5",
            "1.6",
            "1.7",
            "2.0"
        ]
    },
    "processing": {
        "job_timeout_ms": 240000,
        "gs_concurrency": 2,
        "dpi_rebuild": 300
    },
    "autofix": {
        "actions": [
            "add_bleed"
        ],
        "allow_lossy": false
    },
    "checks": {
        "error_on_rgb": false,
        "error_on_missing_bleed": false,
        "error_on_tac_exceeded": true,
        "warn_on_low_resolution": true,
        "warn_on_spot_colors": true,
        "warn_on_type3_fonts": true
    }
}