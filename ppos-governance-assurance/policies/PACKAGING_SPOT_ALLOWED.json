{
    "slug": "PACKAGING_SPOT_ALLOWED",
    "name": "Packaging (Spot/Diecut Allowed)",
    "color": {
        "mode": "cmyk",
        "icc_profile": "PSO_Coated_v3.icc",
        "convert_rgb": true,
        "tac_limit": 300,
        "allow_spot_colors": true,
        "spot_color_whitelist": [
            "CutContour",
            "Varnish",
            "White",
            "Crease",
            "Silver",
            "Gold"
        ],
        "require_output_intent": true,
        "flatten_transparency": true,
        "render_intent": 1
    },
    "document": {
        "bleed_mm_required": 3,
        "min_resolution_dpi": 300,
        "max_pages": 10,
        "max_file_mb": 500,
        "max_spot_colors": 10
    },
    "processing": {
        "job_timeout_ms": 300000,
        "gs_concurrency": 2,
        "dpi_rebuild": 300
    },
    "autofix": {
        "actions": [
            "convert_cmyk",
            "flatten_transparency"
        ],
        "allow_lossy": false
    },
    "checks": {
        "error_on_rgb": true,
        "error_on_missing_bleed": true,
        "error_on_tac_exceeded": true,
        "warn_on_low_resolution": true,
        "warn_on_spot_colors": false,
        "warn_on_type3_fonts": true
    }
