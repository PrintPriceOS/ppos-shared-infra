{
    "slug": "LARGE_FORMAT_RGB_SAFE",
    "name": "Large Format RGB Safe (Signage)",
    "color": {
        "mode": "rgb_allowed",
        "icc_profile": "sRGB_Color_Space_Profile.icc",
        "convert_rgb": false,
        "tac_limit": 350,
        "allow_spot_colors": true,
        "spot_color_whitelist": [
            "CutContour",
            "White"
        ],
        "require_output_intent": false,
        "flatten_transparency": false,
        "render_intent": 0
    },
    "document": {
        "bleed_mm_required": 5,
        "min_resolution_dpi": 150,
        "max_pages": 50,
        "max_file_mb": 1024,
        "max_spot_colors": 5
    },
    "processing": {
        "job_timeout_ms": 600000,
        "gs_concurrency": 2,
        "dpi_rebuild": 150
    },
    "autofix": {
        "actions": [
            "add_bleed"
        ],
        "allow_lossy": true
    },
    "checks": {
        "error_on_rgb": false,
        "error_on_missing_bleed": true,
        "error_on_tac_exceeded": true,
        "warn_on_low_resolution": true,
        "warn_on_spot_colors": false,
        "warn_on_type3_fonts": true
    }
}