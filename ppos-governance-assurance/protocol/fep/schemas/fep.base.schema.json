{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "FEP Base Envelope",
    "type": "object",
    "required": [
        "protocol",
        "message",
        "payload"
    ],
    "properties": {
        "protocol": {
            "type": "object",
            "required": [
                "name",
                "version"
            ],
            "properties": {
                "name": {
                    "const": "FEP"
                },
                "version": {
                    "type": "string",
                    "pattern": "^\\d+\\.\\d+\\.\\d+$"
                },
                "profile": {
                    "type": "string"
                }
            }
        },
        "message": {
            "type": "object",
            "required": [
                "messageId",
                "messageType",
                "timestamp",
                "sourceNodeId"
            ],
            "properties": {
                "messageId": {
                    "type": "string"
                },
                "messageType": {
                    "type": "string"
                },
                "timestamp": {
                    "type": "string",
                    "format": "date-time"
                },
                "sourceNodeId": {
                    "type": "string"
                },
                "targetNodeId": {
                    "type": "string"
                },
                "correlationId": {
                    "type": "string"
                }
            }
        },
        "payload": {
            "type": "object"
        },
        "governance": {
            "type": "object",
            "properties": {
                "policyProfile": {
                    "type": "string"
                },
                "assertionId": {
                    "type": "string"
                }
            }
        },
        "trust": {
            "type": "object",
            "properties": {
                "trustTier": {
                    "type": "string"
                },
                "trustScore": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "trustAssertionId": {
                    "type": "string"
                }
            }
        },
        "evidence": {
            "type": "object",
            "properties": {
                "envelopeRef": {
                    "type": "string"
                }
            }
        },
        "signature": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string"
                },
                "ref": {
                    "type": "string"
                }
            }
        }
    }
}