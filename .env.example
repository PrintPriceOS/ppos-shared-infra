# Example environment file for PDF Preflight Check
# Copy this to a file named .env and set real secret values. DO NOT commit your .env to git.

# API key protecting heavy endpoints (recommended)
PPP_API_KEY=your_api_key_here

# Upload directory (optional). Use a writable path in your container/host.
PPP_UPLOAD_DIR=/tmp/ppp-preflight-uploads

# Memory and worker tuning
PPP_MAX_INMEMORY_PDF_BYTES=209715200
PPP_WORKER_MAX_OLD_SPACE_MB=256

# CORS and rate-limiting
PPP_ALLOWED_ORIGINS=example.com,https://app.example.com
PPP_RATE_LIMIT_WINDOW_MS=60000
PPP_RATE_LIMIT_MAX=10

# SHA and cleanup
PPP_SHA_TIMEOUT_MS=120000
PPP_CLEANUP_MAX_AGE_MS=86400000
PPP_CLEANUP_INTERVAL_MS=3600000

# Deployment mode
NODE_ENV=production

# Admin API Key for external tooling or simple SPA dashboard
VITE_ADMIN_API_KEY=your_admin_api_key_here
ADMIN_API_KEY=your_admin_api_key_here

# Infrastructure
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/preflight_"
REDIS_URL="redis://localhost:6379"

# Tools (Will use system default if empty)
# GS_PATH="C:\\Program Files\\gs\\gs10.03.0\\bin\\gswin64c.exe"
# GS_PATH="/usr/bin/gs"

# PrintPrice OS (PPOS) Integration
PPOS_PREFLIGHT_SERVICE_URL="http://localhost:3000"
PPOS_CONTROL_PLANE_URL="http://localhost:8080"
PPOS_REQUEST_TIMEOUT_MS=30000
PPOS_LONG_REQUEST_TIMEOUT_MS=60000
PPOS_ENABLE_ASYNC_PREFLIGHT=false
PPOS_ENABLE_AUTOFIX=true
PPOS_API_KEY="your_ppos_api_key"
PPOS_ENVIRONMENT=development
