# PrintPrice OS — Master Setup Template
# Industrial Environment Variables

NODE_ENV=development
PPOS_HOME=.
PPOS_TEMP_DIR=./.runtime/tmp
PPOS_UPLOAD_DIR=./.runtime/uploads
PPOS_QUARANTINE_DIR=./.runtime/quarantine

# Database Configuration (Defaults for Docker)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=printprice_os
MYSQL_USER=ppos_user
MYSQL_PASSWORD=ppos_pass

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage & Signing
ASSET_SIGNING_SECRET=ppos-secret-2026
ASSET_CDN_URL=http://localhost:3000

# Binaries
GS_COMMAND=gs

# API Ports
PPOS_PORT=3000
ENGINE_PORT=8001
METRICS_PORT=9090
