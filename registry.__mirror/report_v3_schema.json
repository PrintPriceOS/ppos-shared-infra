{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ReportV3",
    "description": "PrintPrice Production Intelligence Report",
    "type": "object",
    "required": [
        "report_version",
        "decision",
        "technical",
        "production"
    ],
    "properties": {
        "report_version": {
            "type": "string",
            "enum": [
                "3.0"
            ]
        },
        "decision": {
            "type": "object",
            "required": [
                "status",
                "best_printer_id",
                "overall_confidence"
            ],
            "properties": {
                "status": {
                    "type": "string",
                    "enum": [
                        "ready",
                        "conditionally_ready",
                        "not_ready",
                        "error"
                    ]
                },
                "best_printer_id": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "overall_confidence": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "required_actions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "estimated_delta_cost_usd": {
                    "type": "number"
                }
            }
        },
        "technical": {
            "type": "object",
            "required": [
                "risk_score",
                "findings"
            ],
            "properties": {
                "risk_score": {
                    "type": "integer"
                },
                "findings": {
                    "type": "array"
                },
                "engines": {
                    "type": "object"
                }
            }
        },
        "production": {
            "type": "object",
            "properties": {
                "intent": {
                    "type": "object",
                    "properties": {
                        "candidates": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "type": {
                                        "type": "string"
                                    },
                                    "confidence": {
                                        "type": "number"
                                    }
                                }
                            }
                        }
                    }
                },
                "geometry": {
                    "type": "object",
                    "properties": {
                        "findings": {
                            "type": "array"
                        }
                    }
                },
                "binding": {
                    "type": "object",
                    "properties": {
                        "binding_type": {
                            "type": "string"
                        },
                        "theoretical_spine_mm": {
                            "type": "number"
                        },
                        "detected_spine_mm": {
                            "type": [
                                "number",
                                "null"
                            ]
                        },
                        "feasibility_score": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                        },
                        "evidence": {
                            "type": "array"
                        }
                    }
                },
                "compatibility": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "printer_id": {
                                "type": "string"
                            },
                            "status": {
                                "type": "string"
                            },
                            "confidence": {
                                "type": "number"
                            },
                            "required_actions": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "cost_impact": {
                    "type": "object",
                    "properties": {
                        "direct_cost": {
                            "type": "number"
                        },
                        "risk_cost": {
                            "type": "number"
                        },
                        "savings_opportunity": {
                            "type": "number"
                        }
                    }
                }
            }
        }
    }
}