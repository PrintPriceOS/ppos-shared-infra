  "description": "PrintPrice Pro - Production Intelligence Platform",
  "main": "app/server.js",
  "engines": {
    "node": ">=20 <21 || >=22"
  },
  "scripts": {
    "preinstall": "node -e \"const v=process.versions.node.split('.')[0]; if(v<20) {console.error('ERROR: Node.js 20 or 22+ required'); process.exit(1)}\"",
    "dev": "vite frontend --config frontend/vite.config.ts",
    "build": "vite build frontend --config frontend/vite.config.ts",
    "preview": "vite preview frontend --config frontend/vite.config.ts",
    "start": "node app/server.js",
    "test:front": "vitest",
    "boundary-check": "node scripts/boundary-check.js",
    "validate:ppos": "node scripts/validate-ppos-bridge.js"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
