    "@google/generative-ai": "^0.16.0",
    "@heroicons/react": "^2.2.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.2",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dompurify": "^3.3.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "fuse.js": "^7.1.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.0",
    "marked": "^16.4.1",
    "multer": "^2.0.2",
    "mysql2": "^3.18.2",
